{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "_DefaultConnection_example": "Server=localhost;Database=nairabox;User=root;Password=;",
    "DefaultConnection": ""
  },
  "Jwt": {
    "Secret": "CHANGE_ME_IN_PRODUCTION",
    "SecretNote": "Set JWT__Secret environment variable in production",
    "Issuer": "nairabox-api",
    "Audience": "nairabox-client"
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:4300", "https://nairabox-web.vercel.app"]
  },
  "AppSettings": {
    "ServiceFeePercentage": 0.035,
    "OtpExpirationMinutes": 10,
    "RefreshTokenExpirationDays": 7,
    "MinPasswordLength": 6,
    "MaxFeaturedEvents": 10,
    "MaxPopularEvents": 20,
    "DefaultPageSize": 50
  }
}
